# Copy to .env and fill in your keys (both optional — sim falls back gracefully)

# Live weather sync — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Real-time road congestion — https://developer.tomtom.com
TOMTOM_API_KEY=

# Simulated city centre (defaults: Mumbai Naka Circle, Nashik)
# CITY_LAT=19.98708
# CITY_LON=73.78399
# CITY_RADIUS_M=600

# Allowed frontend origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
